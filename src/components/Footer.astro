---
import { SITE } from '../consts';
const year = new Date().getFullYear();
const social = Object.entries(SITE.social).filter(([, url]) => url);
---
<footer class="site-footer">
  <div class="container inner">
    <div class="mark">
      <p class="wordmark">Intuitions behind the world</p>
      <p class="muted tagline">{SITE.description}</p>
    </div>

    <div class="meta">
      <p>© {year} {SITE.author}</p>
      <p class="links">
        <a href="/rss.xml">RSS</a>
        <span aria-hidden="true">·</span>
        <a href="/sitemap-index.xml">Sitemap</a>
        {social.map(([name, url]) => (
          <><span aria-hidden="true">·</span><a href={url} rel="me noopener">{name}</a></>
        ))}
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--c-rule);
    margin-top: clamp(3rem, 8vw, 6rem);
    padding: clamp(2rem, 5vw, 3.5rem) 0 clamp(1.8rem, 4vw, 2.5rem);
    background: var(--c-bg-tint);
  }
  .inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: start;
  }
  .wordmark {
    font-family: var(--font-display);
    font-weight: 400;
    font-variation-settings: 'opsz' 72;
    font-size: 1.2rem;
    color: var(--c-text);
    letter-spacing: -0.01em;
    margin: 0 0 .3rem;
  }
  .tagline { font-size: 0.9rem; margin: 0; max-width: 28rem; }

  .meta {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: var(--c-muted);
    text-align: right;
  }
  .meta p { margin: 0 0 .35rem; }
  .meta a {
    color: var(--c-text-soft);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
  }
  .meta a:hover { color: var(--c-accent); text-decoration: underline; text-underline-offset: 0.2em; }
  .meta .links { display: inline-flex; gap: .55rem; align-items: baseline; flex-wrap: wrap; justify-content: flex-end; }
  .meta .links span { opacity: .5; }

  @media (max-width: 640px) {
    .inner { grid-template-columns: 1fr; }
    .meta { text-align: left; }
    .meta .links { justify-content: flex-start; }
  }
</style>

